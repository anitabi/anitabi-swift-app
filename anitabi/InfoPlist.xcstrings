      }
    },
    "NSCameraUsageDescription" : {
      "comment" : "Privacy - Camera Usage Description",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "We need access to your camera to take photos and compare them with anime scenes."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "アニメのシーンと比較する写真を撮影するために、カメラへのアクセスが必要です。"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "我们需要访问您的相机以便拍摄照片，与动漫场景进行对比。"
          }
        }
      }
    },
    "NSLocationWhenInUseUsageDescription" : {
      "comment" : "Privacy - Location When In Use Usage Description",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "We need your location to show your current position on the pilgrimage map."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "巡礼マップ上に現在地を表示するために、位置情報が必要です。"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "我们需要获取您的位置信息，以便在巡礼地图上显示您目前的位置"
          }
        }
      }
    },
    "NSPhotoLibraryAddUsageDescription" : {
      "comment" : "Privacy - Photo Library Additions Usage Description",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "We need to add photos to your photo library to save anime scene images."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "アニメシーンの画像を保存するために、写真ライブラリへの追加が必要です。"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "我们需要向您的照片库添加照片，以便保存动漫场景图片。"
          }
        }
      }
    },
    "NSPhotoLibraryUsageDescription" : {
      "comment" : "Privacy - Photo Library Usage Description",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "We need access to your photo library so you can choose photos to compare with anime scenes."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "アニメのシーンと比較する写真を選択するために、写真ライブラリへのアクセスが必要です。"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "我们需要访问您的照片库，以便您选择照片与动漫场景进行对比。"
          }
        }
      }
    }
  },
  "version" : "1.0"
}